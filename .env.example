# SimpleCargo environment — NAMES ONLY (никаких реальных значений в репозитории).
# Реальные значения задаются в Railway Variables через reference-синтаксис ${{Service.VAR}}.

# --- Phase 0 (web + Postgres) ---
# App runtime queries (direct Postgres в P1/P2; pooler позже).
DATABASE_URL=
# Только для drizzle-kit migrate — ВСЕГДА прямой Postgres, никогда не pooler.
DATABASE_URL_DIRECT=
# openssl rand -hex 32
BETTER_AUTH_SECRET=
# https://<public-domain>
BETTER_AUTH_URL=
NODE_ENV=
# Часовой пояс отображения (хранит UTC, показывает MSK).
APP_TZ_DISPLAY=Europe/Moscow

# Корень файлового хранилища для документов контрагентов (договоры/заявки/сканы).
# Прод — примонтированный том Railway (например, /data); локально по умолчанию ./.storage.
STORAGE_DIR=./.storage

# --- AI-интейк запросов (OpenRouter) — опционально. Без ключа /api/requests/extract
#     отдаёт 501, ручной ввод работает. Реальное значение — в Railway Variables. ---
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.5-flash
# OPENROUTER_AUDIO_MODEL=google/gemini-2.5-flash

# --- Точка Банк Open API (вкладка «Финансы») — опционально. Без JWT финансовые
#     роуты отдают 501, навигация работает. JWT — СЕКРЕТ, только Railway/.env. ---
# Sandbox по умолчанию; для прода: https://enter.tochka.com/uapi
# TOCHKA_BASE_URL=https://enter.tochka.com/sandbox/v2
# TOCHKA_JWT_TOKEN=
# TOCHKA_CLIENT_ID=
# TOCHKA_CUSTOMER_CODE=
# TOCHKA_WEBHOOK_PUBKEY_URL=https://enter.tochka.com/doc/openapi/static/keys/public
# TOCHKA_PAYER_BIC=044525104
# Публичный HTTPS-URL приёма вебхуков — воркер авто-регистрирует подписку на старте.
# TOCHKA_WEBHOOK_URL=https://app.example.ru/api/finances/tochka/webhook
# Страховочный опрос выписок воркером (мс). 0 = выкл; иначе мин. 60000. По умолч. 900000 (15 мин).
# FINANCE_POLL_MS=900000

# --- Отправка выписок на email (SMTP) — опционально. Без него кнопка email
#     отдаёт 501. Формат: smtp://user:pass@host:587 (или smtps:// для 465). ---
# SMTP_URL=
# SMTP_FROM=РНС Финансы <info@rusnerudstroy.ru>

# Только для разового запуска `pnpm db:seed:user` (не нужны приложению в рантайме).
# SEED_USER_EMAIL=
# SEED_USER_PASSWORD=
# SEED_USER_NAME=

# --- Phase 2+ (worker + Redis + object storage) — пока не используется ---
# REDIS_URL=
# BUCKET_ENDPOINT=
# BUCKET_KEY=
# BUCKET_SECRET=
# BUCKET_NAME=simplecargo-files

# --- Приём почты mail.ru + ИИ (сервис mail-worker) — ОПЦИОНАЛЬНО ---
#     Без MAIL_INTAKE_ENABLED=true и кредов воркер idle-выходит, web работает.
#     Пароль — ПАРОЛЬ ПРИЛОЖЕНИЯ mail.ru (Настройки → Пароли для внешних приложений),
#     задаётся ТОЛЬКО в Railway Variables, не в репозитории.
# MAIL_INTAKE_ENABLED=false
# MAILRU_IMAP_HOST=imap.mail.ru
# MAILRU_IMAP_PORT=993
# MAILRU_IMAP_USER=<ящик>@<домен или mail.ru>
# MAILRU_IMAP_APP_PASSWORD=<пароль приложения>
# MAILRU_IMAP_INBOX=INBOX
# MAILRU_IMAP_PROCESSED_FOLDER=SimpleCargo/Processed
# MAILRU_IMAP_POLL_MS=15000
# Исходящий RFQ перевозчикам и выписки используют уже описанные SMTP_URL/SMTP_FROM
# (smtps://<ящик>%40<домен>:<app-password>@smtp.mail.ru:465). SMTP_FROM ДОЛЖЕН = логину.

# --- Phase 6 (прочее, пока не используется) ---
# ANTHROPIC_API_KEY=
# INGESTION_HMAC_SECRET=
