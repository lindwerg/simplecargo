# SimpleCargo environment — NAMES ONLY (никаких реальных значений в репозитории).
# Реальные значения задаются в Railway Variables через reference-синтаксис ${{Service.VAR}}.

# --- Phase 0 (web + Postgres) ---
# App runtime queries (direct Postgres в P1/P2; pooler позже).
DATABASE_URL=
# Только для drizzle-kit migrate — ВСЕГДА прямой Postgres, никогда не pooler.
DATABASE_URL_DIRECT=
# openssl rand -hex 32
BETTER_AUTH_SECRET=
# https://<public-domain>
BETTER_AUTH_URL=
NODE_ENV=
# Часовой пояс отображения (хранит UTC, показывает MSK).
APP_TZ_DISPLAY=Europe/Moscow

# --- Phase 2+ (worker + Redis + object storage) — пока не используется ---
# REDIS_URL=
# BUCKET_ENDPOINT=
# BUCKET_KEY=
# BUCKET_SECRET=
# BUCKET_NAME=simplecargo-files

# --- Phase 6 (worker, AI/email) ---
# ANTHROPIC_API_KEY=
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=
# INGESTION_HMAC_SECRET=
