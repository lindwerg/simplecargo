# SimpleCargo environment — NAMES ONLY (никаких реальных значений в репозитории).
# Реальные значения задаются в Railway Variables через reference-синтаксис ${{Service.VAR}}.

# --- Phase 0 (web + Postgres) ---
# App runtime queries (direct Postgres в P1/P2; pooler позже).
DATABASE_URL=
# Только для drizzle-kit migrate — ВСЕГДА прямой Postgres, никогда не pooler.
DATABASE_URL_DIRECT=
# openssl rand -hex 32
BETTER_AUTH_SECRET=
# https://<public-domain>
BETTER_AUTH_URL=
NODE_ENV=
# Часовой пояс отображения (хранит UTC, показывает MSK).
APP_TZ_DISPLAY=Europe/Moscow

# Корень файлового хранилища для документов контрагентов (договоры/заявки/сканы).
# Прод — примонтированный том Railway (например, /data); локально по умолчанию ./.storage.
STORAGE_DIR=./.storage

# --- AI-интейк запросов (OpenRouter) — опционально. Без ключа /api/requests/extract
#     отдаёт 501, ручной ввод работает. Реальное значение — в Railway Variables. ---
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.5-flash
# OPENROUTER_AUDIO_MODEL=google/gemini-2.5-flash

# --- Точка Банк Open API (вкладка «Финансы») — опционально. Без JWT финансовые
#     роуты отдают 501, навигация работает. JWT — СЕКРЕТ, только Railway/.env. ---
# Sandbox по умолчанию; для прода: https://enter.tochka.com/uapi
# TOCHKA_BASE_URL=https://enter.tochka.com/sandbox/v2
# TOCHKA_JWT_TOKEN=
# TOCHKA_CLIENT_ID=
# TOCHKA_CUSTOMER_CODE=
# TOCHKA_WEBHOOK_PUBKEY_URL=https://enter.tochka.com/doc/openapi/static/keys/public

# Только для разового запуска `pnpm db:seed:user` (не нужны приложению в рантайме).
# SEED_USER_EMAIL=
# SEED_USER_PASSWORD=
# SEED_USER_NAME=

# --- Phase 2+ (worker + Redis + object storage) — пока не используется ---
# REDIS_URL=
# BUCKET_ENDPOINT=
# BUCKET_KEY=
# BUCKET_SECRET=
# BUCKET_NAME=simplecargo-files

# --- Phase 6 (worker, AI/email) ---
# ANTHROPIC_API_KEY=
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=
# INGESTION_HMAC_SECRET=
