# SimpleCargo environment — NAMES ONLY (никаких реальных значений в репозитории).
# Реальные значения задаются в Railway Variables через reference-синтаксис ${{Service.VAR}}.

# --- Phase 0 (web + Postgres) ---
# App runtime queries (direct Postgres в P1/P2; pooler позже).
DATABASE_URL=
# Только для drizzle-kit migrate — ВСЕГДА прямой Postgres, никогда не pooler.
DATABASE_URL_DIRECT=
# openssl rand -hex 32
BETTER_AUTH_SECRET=
# https://<public-domain>
BETTER_AUTH_URL=
NODE_ENV=
# Часовой пояс отображения (хранит UTC, показывает MSK).
APP_TZ_DISPLAY=Europe/Moscow

# --- AI-интейк запросов (OpenRouter) — опционально. Без ключа /api/requests/extract
#     отдаёт 501, ручной ввод работает. Реальное значение — в Railway Variables. ---
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.5-flash
# OPENROUTER_AUDIO_MODEL=google/gemini-2.5-flash

# Только для разового запуска `pnpm db:seed:user` (не нужны приложению в рантайме).
# SEED_USER_EMAIL=
# SEED_USER_PASSWORD=
# SEED_USER_NAME=

# --- Phase 2+ (worker + Redis + object storage) — пока не используется ---
# REDIS_URL=
# BUCKET_ENDPOINT=
# BUCKET_KEY=
# BUCKET_SECRET=
# BUCKET_NAME=simplecargo-files

# --- Phase 6 (worker, AI/email) ---
# ANTHROPIC_API_KEY=
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=
# INGESTION_HMAC_SECRET=
